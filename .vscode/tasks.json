{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run current PHP file",
      "type": "shell",
      "command": "C:\\xampp\\php\\php.exe",
      "args": [
        "${file}"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Start PHP server on localhost:8000",
      "type": "shell",
      "command": "C:\\xampp\\php\\php.exe",
      "args": [
        "-S",
        "localhost:8000",
        "-t",
        "${workspaceFolder}"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
